rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: QuestionBank
    // Fields:
    //   - id: string (required, < 100 chars)
    //   - questionText: string (required, < 2000 chars)
    //   - choices: list (required, 2-10 items)
    //   - correctAnswerIndex: number (required, valid index)
    //   - explanation: string (required, < 3000 chars)
    //   - category: string (required, < 50 chars)
    //   - createdAt: number (required)
    //
    // Collection: QuizResults
    // Fields:
    //   - respondentName: string (required, < 100 chars)
    //   - category: string (required, < 50 chars)
    //   - score: number (required, >= 0)
    //   - total: number (required, > 0)
    //   - answeredIds: list (optional, < 100 items)
    //   - createdAt: number (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "tropmed.cu@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidQuestion(data) {
      let requiredFields = ['id', 'questionText', 'choices', 'correctAnswerIndex', 'explanation', 'category', 'createdAt'];
      return data.keys().hasAll(requiredFields) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.questionText is string && data.questionText.size() > 0 && data.questionText.size() < 2000 &&
             data.choices is list && data.choices.size() >= 2 && data.choices.size() <= 10 &&
             data.correctAnswerIndex is number && data.correctAnswerIndex >= 0 && data.correctAnswerIndex < data.choices.size() &&
             data.explanation is string && data.explanation.size() < 3000 &&
             data.category is string && data.category.size() > 0 && data.category.size() < 50 &&
             data.createdAt is number;
    }

    function isValidQuizResult(data) {
      let requiredFields = ['respondentName', 'category', 'score', 'total', 'createdAt'];
      return data.keys().hasAll(requiredFields) &&
             data.respondentName is string && data.respondentName.size() > 0 && data.respondentName.size() < 100 &&
             data.category is string && data.category.size() > 0 && data.category.size() < 50 &&
             data.score is number && data.score >= 0 &&
             data.total is number && data.total > 0 &&
             data.createdAt is number &&
             (!('answeredIds' in data) || (data.answeredIds is list && data.answeredIds.size() <= 100));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /QuestionBank/{questionId} {
      // Allow read for everyone (authenticated or not) to access the bank
      allow read: if true;
      // Allow everyone to create questions in the bank if they are valid (caching)
      allow create: if isValidQuestion(request.resource.data);
      // Only admin can update/delete questions in the bank
      allow update: if isAdmin() && isValidQuestion(request.resource.data);
      allow delete: if isAdmin();
    }

    match /QuizResults/{resultId} {
      // Allow read for everyone to check for answered questions
      allow read: if true;
      // Allow create for everyone to save results
      allow create: if isValidQuizResult(request.resource.data);
      // Only admin can update/delete results
      allow update: if isAdmin() && isValidQuizResult(request.resource.data);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }
  }
}
